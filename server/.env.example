# ══════════════════════════════════════════
#  ИРИДА — переменные окружения
# ══════════════════════════════════════════

# === Основные настройки ===
DOMAIN=disp.example.ru
EMAIL=admin@example.ru
ENVIRONMENT=production

# === База данных ===
DB_PASSWORD=сгенерируй_надёжный_пароль_32_символа

# === Секретный ключ (JWT, сессии) ===
SECRET_KEY=сгенерируй_случайную_строку_48_символов

# === Схема БД (по умолчанию public) ===
MAIN_DB_SCHEMA=public

# === S3 хранилище (файлы, аудио, аватары) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === Yandex SpeechKit (транскрибация аудио) ===
YANDEX_SPEECHKIT_KEY=

# === Redis (опционально, по умолчанию без пароля) ===
# REDIS_PASSWORD=пароль_redis
