{
  "tests": [
    {
      "name": "Login with valid employee_id + PIN",
      "method": "POST",
      "path": "/?action=login",
      "body": {"employee_id": "0001", "pin": "1234"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with invalid credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"employee_id": "0001", "pin": "0000"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Get online drivers",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"drivers": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Rate dispatcher without auth",
      "method": "POST",
      "path": "/?action=rate_dispatcher",
      "body": {"rating": 5},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Rate dispatcher invalid rating",
      "method": "POST",
      "path": "/?action=rate_dispatcher",
      "headers": {"X-Auth-Token": "invalid"},
      "body": {"rating": 0},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}