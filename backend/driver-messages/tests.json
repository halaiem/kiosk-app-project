{
  "tests": [
    {
      "name": "Get messages for driver",
      "method": "GET",
      "path": "/?driver_id=1",
      "expectedStatus": 200
    },
    {
      "name": "Send message as dispatcher",
      "method": "POST",
      "path": "/",
      "body": {"driver_id": 1, "text": "Тест диспетчера", "type": "normal"},
      "expectedStatus": 200
    },
    {
      "name": "Confirm delivery",
      "method": "POST",
      "path": "/?action=confirm_delivery",
      "body": {"message_ids": [1]},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Batch without token unauthorized",
      "method": "POST",
      "path": "/?action=batch",
      "body": {"messages": []},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}