# ══════════════════════════════════════════
#  ИРИДА — переменные окружения для Dokploy
# ══════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_USER=irida
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=irida

# ── Schema (оставь public или укажи кастомную) ──
MAIN_DB_SCHEMA=public

# ── S3 хранилище (для файлов, аудио, аватаров) ──
# Получи ключи в панели Поехали: Ядро → Секреты
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Yandex SpeechKit (транскрибация аудио) ──
# https://yandex.cloud/ru/docs/speechkit/
YANDEX_SPEECHKIT_KEY=

# ── Backend URL (для фронтенда) ──
# Укажи URL на котором доступен бэкенд
# Примеры:
#   http://localhost:8000       — локальная разработка
#   https://api.mysite.ru       — продакшен с доменом
VITE_API_BASE_URL=http://localhost:8000
